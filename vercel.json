{
    "version": 2,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/debug.php",
            "dest": "/api/test.php"
        },
        {
            "src": "/api/test.php",
            "dest": "/api/test.php"
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|img|images|vendor|favicon.ico|robots.txt|manifest.json)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/((?!api/test\\.php).*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "DB_CONNECTION": "pgsql",
        "ASSET_URL": "https://thiottys.vercel.app",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "VIEW_COMPILED_PATH": "/tmp/views"
    }
}
